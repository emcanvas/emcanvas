# Copy these placeholders into your shell or a local-only env file before running the Docker smoke wrapper.
# EmCanvas does not patch or vendor EmDash upstream; you must supply the host image, runtime env, and seed credentials.

EMDASH_IMAGE=
EMDASH_ENV_FILE=
EMDASH_HOST_PORT=3000
EMDASH_CONTAINER_PORT=3000
EMDASH_SEED_ENDPOINT=
EMDASH_SEED_TOKEN=
