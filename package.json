{
  "name": "emcanvas",
  "version": "0.1.0",
  "private": true,
  "description": "A visual page builder for EmDash.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./sandbox": "./dist/sandbox-entry.mjs",
    "./admin": "./dist/admin.mjs",
    "./astro": "./dist/astro.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check package.json .prettierrc.json tests/contracts/prettier-config.test.ts",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "astro": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "astro": "^4.16.18",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.1",
    "prettier": "^3.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-git-hooks": "^2.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vite": "^5.4.18",
    "vitest": "^2.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  }
}
